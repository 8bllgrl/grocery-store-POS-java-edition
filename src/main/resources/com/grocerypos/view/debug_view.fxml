<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ScrollPane?>

<VBox
    prefWidth="420"
    prefHeight="580"
    spacing="0"
    style="-fx-background-color: #0a0a0a; -fx-font-family: 'Courier New';"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.grocerypos.controller.DebugController">

    <!-- Title bar -->
    <HBox style="-fx-background-color: #1a1a1a; -fx-padding: 8 12;" spacing="10" alignment="CENTER_LEFT">
        <Label text="▶" style="-fx-text-fill: #00ff41; -fx-font-size: 11px;"/>
        <Label text="DEBUG CONSOLE" style="-fx-text-fill: #00ff41; -fx-font-size: 11px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="MODE: SIMULATION" style="-fx-text-fill: #444444; -fx-font-size: 10px;"/>
    </HBox>

    <Separator style="-fx-background-color: #00ff41; -fx-opacity: 0.3;"/>

    <!-- Session log -->
    <VBox style="-fx-padding: 10 12 6 12;" spacing="3">
        <Label text="/$ grocerypos debug" style="-fx-text-fill: #555555; -fx-font-size: 10px;"/>
        <Label text="  [OK] Debug mode active" style="-fx-text-fill: #00aa2e; -fx-font-size: 10px;"/>
        <Label text="  [OK] CartService bound" style="-fx-text-fill: #00aa2e; -fx-font-size: 10px;"/>
        <Label text="  [  ] Awaiting scan trigger..." style="-fx-text-fill: #555555; -fx-font-size: 10px;"/>
    </VBox>

    <Separator style="-fx-background-color: #222222;"/>

    <!-- Catalog list -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 12;" spacing="6">
        <Label text="── PRODUCT CATALOG / CONVEYOR SIMULATOR ──" style="-fx-text-fill: #336633; -fx-font-size: 10px;"/>
        <Label text="" style="-fx-font-size: 4px;"/>

        <!-- Each row: barcode + name on left, SCAN button on right -->
        <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: #111111; -fx-padding: 8 10; -fx-background-radius: 3;">
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="[111]  WW Muesli Bars 6pk" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
                <Label text="       /$4.50 / unit" style="-fx-text-fill: #555555; -fx-font-size: 10px;"/>
            </VBox>
            <Button text="SCAN" onAction="#scanMuesli"
                style="-fx-background-color: #003300; -fx-text-fill: #00ff41; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #00aa2e; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2; -fx-padding: 6 14; -fx-cursor: hand;"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: #111111; -fx-padding: 8 10; -fx-background-radius: 3;">
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="[222]  Full Cream Milk 2L" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
                <Label text="       /$3.10 / unit" style="-fx-text-fill: #555555; -fx-font-size: 10px;"/>
            </VBox>
            <Button text="SCAN" onAction="#scanMilk"
                style="-fx-background-color: #003300; -fx-text-fill: #00ff41; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #00aa2e; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2; -fx-padding: 6 14; -fx-cursor: hand;"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: #111111; -fx-padding: 8 10; -fx-background-radius: 3;">
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="[333]  Thick Cut Chips 175g" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
                <Label text="       /$4.80 / unit" style="-fx-text-fill: #555555; -fx-font-size: 10px;"/>
            </VBox>
            <Button text="SCAN" onAction="#scanChips"
                style="-fx-background-color: #003300; -fx-text-fill: #00ff41; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #00aa2e; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2; -fx-padding: 6 14; -fx-cursor: hand;"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: #111111; -fx-padding: 8 10; -fx-background-radius: 3;">
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="[444]  Cadbury Dairy Milk" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
                <Label text="       /$5.50 / unit" style="-fx-text-fill: #555555; -fx-font-size: 10px;"/>
            </VBox>
            <Button text="SCAN" onAction="#scanDairyMilk"
                style="-fx-background-color: #003300; -fx-text-fill: #00ff41; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #00aa2e; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2; -fx-padding: 6 14; -fx-cursor: hand;"/>
        </HBox>

        <Region VBox.vgrow="ALWAYS"/>

        <!-- Status line updated by controller -->
        <Separator style="-fx-background-color: #1a1a1a;"/>
        <Label fx:id="lblDebugStatus" text="&gt; ready" style="-fx-text-fill: #336633; -fx-font-size: 10px; -fx-padding: 4 0 0 0;"/>
    </VBox>
</VBox>
