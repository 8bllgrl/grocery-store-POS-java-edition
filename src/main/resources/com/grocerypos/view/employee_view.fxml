<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>

<VBox prefWidth="1024.0" prefHeight="768.0"
    style="-fx-background-color: #111111;"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.grocerypos.controller.EmployeeController">

    <!-- ── TopBar component ───────────────────────────────────────────────── -->
    <fx:include fx:id="topBar" source="components/top_bar.fxml"/>

    <!-- ── Screen stack ──────────────────────────────────────────────────── -->
    <StackPane VBox.vgrow="ALWAYS">

        <!-- Ad / idle screen -->
        <VBox fx:id="paneAd" alignment="CENTER"
            style="-fx-background-color: #0d2c16;"
            onMouseClicked="#handleAdClick">
            <Label text="WOOLWORTHS ENTERPRISE POS"
                style="-fx-text-fill: #2ecc71; -fx-font-size: 32px; -fx-font-weight: bold;"/>
            <Label text="[ REGISTER IDLE - TAP MONITOR TO BEGIN OUTLET SESSION ]"
                style="-fx-text-fill: white; -fx-font-size: 14px;"/>
        </VBox>

        <!-- Login screen -->
        <HBox fx:id="paneLogin" visible="false" alignment="CENTER" spacing="50"
            style="-fx-background-color: #2c3e50;">
            <VBox alignment="CENTER" spacing="15">
                <Label text="WOOLWORTHS"
                    style="-fx-text-fill: #2ecc71; -fx-font-size: 40px; -fx-font-weight: bold;"/>
                <Label text="Store System Terminal Gateway" style="-fx-text-fill: #bdc3c7;"/>
            </VBox>
            <VBox alignment="CENTER" spacing="15"
                style="-fx-background-color: #34495e; -fx-padding: 30; -fx-background-radius: 8;">
                <Label text="Secure Portal Authentication"
                    style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="INITIALIZE LOGIN SEQUENCE" onAction="#handleLoginClick"
                    style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 24;"/>
            </VBox>
        </HBox>

        <!-- Credentials screen (numpad login) -->
        <VBox fx:id="paneCredentials" visible="false" alignment="CENTER" spacing="20"
            style="-fx-background-color: #2c3e50;">
            <VBox maxWidth="400" spacing="15"
                style="-fx-background-color: #34495e; -fx-padding: 30; -fx-background-radius: 8;">
                <Label text="ENTER OPERATOR ID NUMBER"
                    style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <TextField fx:id="txtUsername"/>
                <PasswordField fx:id="txtPassword"/>
                <!-- NumpadComponent — configured with ENT/CLR via EmployeeController.wireComponents() -->
                <fx:include fx:id="credNumpad" source="components/numpad.fxml"/>
            </VBox>
        </VBox>

        <!-- Loading screen -->
        <VBox fx:id="paneLoading" visible="false" alignment="CENTER" spacing="15"
            style="-fx-background-color: #111111;">
            <ProgressIndicator prefWidth="60" prefHeight="60"/>
            <Label text="Allocating Session Infrastructure. Please standby..."
                style="-fx-text-fill: #95a5a6;"/>
        </VBox>

        <!-- Main POS screen -->
        <VBox fx:id="paneMainPOS" visible="false">
            <HBox VBox.vgrow="ALWAYS">

                <!-- Left: cart table -->
                <VBox HBox.hgrow="ALWAYS" prefWidth="600"
                    style="-fx-padding: 15; -fx-background-color: #1c2833;">
                    <TableView fx:id="tableCart" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colName"      text="Item Name (Abbrv)" prefWidth="240"/>
                            <TableColumn fx:id="colQty"       text="Qty"               prefWidth="60"/>
                            <TableColumn fx:id="colUnitPrice" text="Unit Price"         prefWidth="100"/>
                            <TableColumn fx:id="colLineTotal" text="Line Total"         prefWidth="120"/>
                        </columns>
                    </TableView>
                    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                        <Label text="RUNNING BALANCE DUE: "
                            style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblTotalBalance" text="/$0.00"
                            style="-fx-text-fill: #2ecc71; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </HBox>
                </VBox>

                <!-- Right: controls panel -->
                <VBox prefWidth="424"
                    style="-fx-padding: 15; -fx-background-color: #2c3e50;"
                    spacing="15">

                    <Label text="MANUAL PRODUCT REGISTRY INPUT"
                        style="-fx-text-fill: #bdc3c7; -fx-font-weight: bold;"/>
                    <HBox spacing="10">
                        <TextField fx:id="txtScannerBuffer" HBox.hgrow="ALWAYS"/>
                        <Button text="ENTER CODE" onAction="#handleManualScan"
                            style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                    </HBox>

                    <Label text="ITEM QUANTITY MULTIPLIER NUMPAD"
                        style="-fx-text-fill: #bdc3c7; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Pending Multiplier Scale:" style="-fx-text-fill: white;"/>
                        <Label fx:id="lblMultiplierScale" text="1"
                            style="-fx-text-fill: #e67e22; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    </HBox>

                    <!-- NumpadComponent — configured with QTY/CLR via EmployeeController.wireComponents() -->
                    <fx:include fx:id="posNumpad" source="components/numpad.fxml"/>

                    <Region VBox.vgrow="ALWAYS"/>
                    <HBox spacing="10">
                        <Button text="CASH SALE"   onAction="#handlePaymentAction"
                            prefWidth="150" prefHeight="60"
                            style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Button text="EFTPOS CARD" onAction="#handlePaymentAction"
                            prefWidth="150" prefHeight="60"
                            style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- StatusBar component -->
            <fx:include fx:id="statusBar" source="components/status_bar.fxml"/>
        </VBox>

    </StackPane>
</VBox>
