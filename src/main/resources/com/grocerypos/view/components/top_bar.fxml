<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>

<!--
    TopBarComponent — application header bar with store info, operator name, and live clock.
    Parent calls TopBarController.setOperatorName() to update after login/logout.
-->
<HBox spacing="20"
    style="-fx-background-color: #1a252f; -fx-padding: 10;"
    alignment="CENTER_LEFT"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.grocerypos.controller.component.TopBarController">

    <Label text="GroceryPOS v0.1.0"       style="-fx-text-fill: #bdc3c7; -fx-font-weight: bold;"/>
    <Label text="Store #4021 - Springfield" style="-fx-text-fill: #bdc3c7;"/>
    <Region HBox.hgrow="ALWAYS"/>
    <Label fx:id="lblEmployee" text="Operator: Not Authenticated"
        style="-fx-text-fill: #3498db; -fx-font-weight: bold;"/>
    <Label fx:id="lblClock" text="00:00:00"
        style="-fx-text-fill: #2ecc71; -fx-font-family: 'Courier New'; -fx-font-size: 14px; -fx-font-weight: bold;"/>

</HBox>
